# ── BRUECKENBAUER GMBH — Environment Variables ──────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Analytics (optional) ────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Contact / RFQ form (optional) ───────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# CONTACT_EMAIL=info@brueckenbauer.com

# ── Rate limiting (optional, for form endpoints) ─────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Resend Email Integration (optional) ──────────────────────────
# RESEND_API_KEY=re_XXXXXXX
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_TO_EMAIL=info@brueckenbauer.com


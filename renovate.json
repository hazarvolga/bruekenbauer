{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 7am on Monday"],
  "timezone": "Europe/Berlin",
  "labels": ["dependencies"],
  "assignees": ["hazarekiz"],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchPackageNames": ["next", "react", "react-dom", "framer-motion"],
      "automerge": false,
      "reviewers": ["hazarekiz"]
    },
    {
      "matchPackageNames": ["typescript", "tailwindcss"],
      "automerge": false
    }
  ],
  "ignorePaths": ["brueckenbauer_*_motion_ready/**", "cinematic_macro/**"]
}
